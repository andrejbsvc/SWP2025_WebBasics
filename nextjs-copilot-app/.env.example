# Environment Variables

# GitHub Personal Access Token (required for MCP GitHub server)
# Get your token at: https://github.com/settings/tokens
# Required scopes: repo
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here

# Figma Personal Access Token (required for MCP Figma server)
# Get your token at: https://www.figma.com/settings
FIGMA_PERSONAL_ACCESS_TOKEN=your_figma_token_here

# Next.js Environment Variables
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Add your project-specific environment variables below:
